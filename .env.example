# Server
PORT=8000
LOG_LEVEL=INFO
API_BEARER_TOKEN=change-this-secret-token

# OpenAI -- one key covers all OpenAI stages
OPENAI_API_KEY=sk-...
OPENAI_CONCEPT_MODEL=gpt-4o-mini
OPENAI_IMAGE_MODEL=gpt-image-2
OPENAI_IMAGE_FALLBACK_MODEL=gpt-image-1.5
OPENAI_IMAGE_FALLBACK_MODEL_2=gpt-image-1-mini
OPENAI_QA_MODEL=gpt-4.1
OPENAI_IMAGE_QUALITY=medium

# HuggingFace -- free tier fallback (FLUX.1-schnell)
# Leave empty to disable; image generation raises 500 after gpt-image-1-mini also fails
HF_TOKEN=hf_...

# Cloudflare R2
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET_NAME=camion-images
R2_PUBLIC_URL=https://pub-xxxxxxxxxxxxxxxx.r2.dev

# Feature flags
QA_ENABLED=true
QA_RETRY_LIMIT=2
QA_BRAND_FIDELITY_THRESHOLD=4
IMAGE_TIMEOUT=120
LLM_TIMEOUT=60
# CTA overlay disabled per spec acceptance criteria correction.
# Set to true only when re-enabled by client.
CTA_OVERLAY_ENABLED=false
# Spend ceiling: max image generations per restaurant per day (returns 429 when exceeded)
MAX_IMAGES_PER_RESTAURANT_PER_DAY=50

# Frontend
API_URL=http://localhost:8000
