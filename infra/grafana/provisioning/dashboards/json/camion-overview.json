{
  "title": "Camion Image Generator — Overview",
  "uid": "camion-overview",
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "timezone": "browser",
  "time": { "from": "now-24h", "to": "now" },
  "refresh": "30s",
  "panels": [
    {
      "id": 1,
      "title": "Request rate by QA outcome",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (qa_passed) (rate(image_generation_requests_total[5m]))",
          "legendFormat": "qa_passed={{qa_passed}}"
        }
      ]
    },
    {
      "id": 2,
      "title": "QA pass rate (last 24h)",
      "type": "stat",
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "percentunit" }, "overrides": [] },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(increase(image_generation_requests_total{qa_passed=\"true\"}[24h])) / sum(increase(image_generation_requests_total[24h]))",
          "legendFormat": "qa pass rate"
        }
      ]
    },
    {
      "id": 3,
      "title": "Total requests (last 24h)",
      "type": "stat",
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(increase(image_generation_requests_total[24h]))",
          "legendFormat": "requests"
        }
      ]
    },
    {
      "id": 4,
      "title": "End-to-end latency (p50 / p95)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.50, sum(rate(image_generation_latency_seconds_bucket[15m])) by (le))",
          "legendFormat": "p50"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.95, sum(rate(image_generation_latency_seconds_bucket[15m])) by (le))",
          "legendFormat": "p95"
        }
      ]
    },
    {
      "id": 5,
      "title": "Per-stage latency (avg)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (stage) (rate(stage_latency_seconds_sum[15m])) / sum by (stage) (rate(stage_latency_seconds_count[15m]))",
          "legendFormat": "{{stage}}"
        }
      ]
    },
    {
      "id": 6,
      "title": "Cost per request, avg (last 24h)",
      "type": "stat",
      "gridPos": { "h": 8, "w": 6, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "currencyUSD", "decimals": 4 }, "overrides": [] },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(increase(image_generation_cost_usd_sum[24h])) / sum(increase(image_generation_cost_usd_count[24h]))",
          "legendFormat": "avg cost"
        }
      ]
    },
    {
      "id": 7,
      "title": "Total spend (last 24h)",
      "type": "stat",
      "gridPos": { "h": 8, "w": 6, "x": 6, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "currencyUSD", "decimals": 3 }, "overrides": [] },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(increase(image_generation_cost_usd_sum[24h]))",
          "legendFormat": "total spend"
        }
      ]
    },
    {
      "id": 8,
      "title": "CLIP item-alignment score (avg)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "min": 0, "max": 1 }, "overrides": [] },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(clip_score_sum[15m])) / sum(rate(clip_score_count[15m]))",
          "legendFormat": "avg CLIP score"
        }
      ]
    },
    {
      "id": 9,
      "title": "QA retries by reason",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (reason) (rate(qa_retry_total[15m]))",
          "legendFormat": "{{reason}}"
        }
      ]
    },
    {
      "id": 10,
      "title": "Synthesis fallback rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (to_model) (rate(synthesis_fallback_total[15m]))",
          "legendFormat": "fell back to {{to_model}}"
        }
      ]
    }
  ]
}
